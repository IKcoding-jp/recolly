# === 外部API キー ===
# 各APIの取得手順は下記を参照。全て無料プランで取得可能。

# TMDB（映画・ドラマ）
# 取得先: https://www.themoviedb.org/settings/api
# 手順: アカウント作成 → Settings → API → Developer Plan（個人利用）→ APIキー（v3 auth）をコピー
TMDB_API_KEY=your_tmdb_api_key

# Google Books（本）
# 取得先: https://console.cloud.google.com/apis
# 手順: プロジェクト作成 → APIライブラリ → Books API有効化 → 認証情報 → APIキー作成 → 「一般公開データ」を選択
GOOGLE_BOOKS_API_KEY=your_google_books_api_key

# IGDB（ゲーム）— Twitch Developer Console経由
# 取得先: https://dev.twitch.tv/console
# 手順: Twitchアカウント作成 → アプリ登録（カテゴリ: Application Integration, リダイレクトURL: http://localhost）→ Client ID/Secretをコピー
IGDB_CLIENT_ID=your_igdb_client_id
IGDB_CLIENT_SECRET=your_igdb_client_secret

# AniList（アニメ・漫画）はAPIキー不要（公開GraphQL API）

# === インフラ ===
REDIS_URL=redis://redis:6379/0
